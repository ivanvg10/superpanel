# Renombra este archivo a .env en /server antes de correr
# cp env.example server/.env

# ─── SERVER ───────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# ─── DATABASE ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/superpanel

# ─── SEED (usuario inicial) ────────────────────────────────
ADMIN_EMAIL=ivan@leonventures.com
ADMIN_PASSWORD=replace-with-secure-password

# ─── CORS ─────────────────────────────────────────────────
# Dev: http://localhost:5173  |  Prod: https://superpanel.vercel.app
CLIENT_URL=http://localhost:5173

# ─── CLIENT (solo si Vite no puede hacer proxy en prod) ────
# VITE_API_URL=https://superpanel-server.railway.app
